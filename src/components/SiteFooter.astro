---
import { siteConfig } from "../config/site";
import Icon from "./Icon.astro";

const year = new Date().getFullYear();
const hasLegal = !siteConfig.legal.adminName.startsWith("ADMIN_NAME_PLACEHOLDER");
---

<footer class="relative mt-24 border-t border-[var(--color-border)] bg-[var(--color-bg-subtle)]">
  <div class="relative mx-auto grid max-w-6xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-[1.4fr_1fr_1fr] lg:px-8">
    <div>
      <a href="/" class="flex items-center gap-3 no-underline text-[var(--color-text)]">
        <Icon name="logo" size={40} />
        <span class="flex flex-col leading-tight">
          <span class="font-serif text-[1.1rem] font-semibold">Regeneracja Falowników</span>
          <span class="text-[0.72rem] uppercase tracking-[0.16em] text-[var(--color-text-faint)]">Serwis · Diagnoza · Hamownia</span>
        </span>
      </a>
      <p class="mt-5 max-w-[42ch] text-[0.95rem] text-[var(--color-text-muted)]">
        Naprawa, regeneracja i przeglądy okresowe przemienników częstotliwości
        wszystkich marek. Testy pod obciążeniem, 12 miesięcy gwarancji.
      </p>
      <p class="mt-4 max-w-[42ch] text-[0.9rem] text-[var(--color-text-muted)]">
        Część firmy <strong class="text-[var(--color-text)]">INVERTO</strong> — pełna oferta serwisowa:{" "}
        <a href="https://inwerto.pl" rel="noopener" class="text-[var(--color-accent)]">inwerto.pl</a>.
      </p>
    </div>

    <div>
      <p class="text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Strona</p>
      <ul class="mt-4 space-y-2.5 text-[0.95rem]">
        <li><a href="/#oferta" class="text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text)]">Co naprawiamy</a></li>
        <li><a href="/#proces" class="text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text)]">Jak wygląda naprawa</a></li>
        <li><a href="/#przeglady" class="text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text)]">Przeglądy okresowe</a></li>
        <li><a href="/#faq" class="text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text)]">FAQ</a></li>
        {siteConfig.features.hasBlog && (
          <li><a href="/blog" class="text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text)]">Blog</a></li>
        )}
      </ul>
    </div>

    <div>
      <p class="text-[0.72rem] font-semibold uppercase tracking-[0.14em] text-[var(--color-text-faint)]">Kontakt</p>
      <ul class="mt-4 space-y-3 text-[0.95rem]">
        <li class="flex items-center gap-2 text-[var(--color-text-muted)]">
          <Icon name="mail" size={16} class="text-[var(--color-accent)]" />
          <a href={`mailto:${siteConfig.contact.email}`} class="no-underline hover:text-[var(--color-text)]">{siteConfig.contact.email}</a>
        </li>
        {siteConfig.contact.phone && (
          <li class="flex items-center gap-2 text-[var(--color-text-muted)]">
            <Icon name="phone" size={16} class="text-[var(--color-accent)]" />
            <a href={`tel:${siteConfig.contact.phone.replace(/\s/g, "")}`} class="no-underline hover:text-[var(--color-text)]">{siteConfig.contact.phone}</a>
          </li>
        )}
        {hasLegal && (
          <>
            <li class="text-[var(--color-text-muted)] pt-2 border-t border-[var(--color-border)]">{siteConfig.legal.adminName}</li>
            <li class="text-[var(--color-text-muted)] text-sm">{siteConfig.legal.adminAddress}</li>
            <li class="text-[var(--color-text-muted)] text-sm font-mono">NIP: {siteConfig.legal.adminNip}</li>
          </>
        )}
      </ul>
    </div>
  </div>

  <div class="relative border-t border-[var(--color-border)]">
    <div class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-2 px-4 py-5 text-xs text-[var(--color-text-faint)] sm:flex-row sm:items-center sm:px-6 lg:px-8">
      <p>© {year} {siteConfig.name}. Wszystkie prawa zastrzeżone.</p>
      <p><a href="/polityka-prywatnosci" class="text-[var(--color-text-muted)]">Polityka prywatności</a></p>
    </div>
  </div>
</footer>
