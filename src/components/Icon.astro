---
// Solidnie wykonane ikony 24x24 (stroke 1.75) — inline SVG.
// Większość zaadaptowana z Heroicons / Lucide / Tabler, ale tematycznie.
interface Props {
  name:
    | "diagnostic" | "report" | "decision" | "wrench" | "dyno" | "shield-check"
    | "fan" | "capacitor" | "bolt" | "factory" | "clock" | "checklist"
    | "wallet" | "warehouse" | "headset" | "arrow-right" | "chevron-right"
    | "send" | "mail" | "phone" | "clock-hours" | "wave" | "logo";
  class?: string;
  size?: number;
}
const { name, class: className = "", size = 24 } = Astro.props;
const cls = `inline-block ${className}`;
---
{name === "diagnostic" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M3 12h3l2-7 4 14 2-7h7"/>
    <circle cx="20" cy="5" r="1.5" fill="currentColor"/>
  </svg>
)}
{name === "report" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"/>
    <path d="M14 3v5h5"/>
    <path d="M9 13h6M9 17h4M9 9h1"/>
  </svg>
)}
{name === "decision" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M8 7h12M8 12h12M8 17h7"/>
    <rect x="2" y="5" width="3" height="4" rx="0.5"/>
    <rect x="2" y="10" width="3" height="4" rx="0.5"/>
    <path d="M2 16l1.5 1.5L6 15"/>
  </svg>
)}
{name === "wrench" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M14.7 6.3a4 4 0 0 0-5.4 5.4l-7 7 2 2 7-7a4 4 0 0 0 5.4-5.4l-2.5 2.5-2.5-2.5 2.5-2.5z"/>
    <path d="M18 14l4 4-2 2-4-4"/>
  </svg>
)}
{name === "dyno" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <circle cx="12" cy="12" r="9"/>
    <path d="M12 12l5-3"/>
    <path d="M5.5 8.5l1.5 1M18.5 8.5l-1.5 1M5.5 15.5l1.5-1M18.5 15.5l-1.5-1M12 5v2M12 17v2"/>
    <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
  </svg>
)}
{name === "shield-check" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M12 2l8 3v7c0 4.5-3 8-8 10-5-2-8-5.5-8-10V5z"/>
    <path d="M9 12l2 2 4-4"/>
  </svg>
)}
{name === "fan" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M12 12c0-3 1-7 4-7s4 4 1 7-7 4-7 4z" />
    <path d="M12 12c3 0 7 1 7 4s-4 4-7 1 -4-7-4-7z" />
    <path d="M12 12c0 3-1 7-4 7s-4-4-1-7 7-4 7-4z" />
    <circle cx="12" cy="12" r="1.6" fill="currentColor"/>
  </svg>
)}
{name === "capacitor" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <rect x="6" y="5" width="12" height="14" rx="1.5"/>
    <path d="M9 5V3M15 5V3M9 19v2M15 19v2"/>
    <path d="M10 10h4M12 8v4" stroke-width="1.4"/>
  </svg>
)}
{name === "bolt" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="currentColor" class={cls} aria-hidden="true">
    <path d="M13 2L4 14h6l-1 8 9-12h-6z"/>
  </svg>
)}
{name === "factory" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M3 21V11l5 3V11l5 3V8l8-4v17z"/>
    <path d="M7 17h1M11 17h1M15 17h1M19 17h1"/>
  </svg>
)}
{name === "clock" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <circle cx="12" cy="12" r="9"/>
    <path d="M12 7v5l3 2"/>
  </svg>
)}
{name === "checklist" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M9 5l1 1 2-2M9 12l1 1 2-2M9 19l1 1 2-2"/>
    <path d="M16 5h5M16 12h5M16 19h5"/>
  </svg>
)}
{name === "wallet" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M3 7a2 2 0 0 1 2-2h12v4H5a2 2 0 0 0-2 2v0"/>
    <path d="M3 11v8a2 2 0 0 0 2 2h15a1 1 0 0 0 1-1v-4M21 16v-3a1 1 0 0 0-1-1H5a2 2 0 0 1-2-2"/>
    <circle cx="17" cy="14.5" r="1.2" fill="currentColor"/>
  </svg>
)}
{name === "warehouse" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M3 21V8l9-5 9 5v13"/>
    <path d="M7 21v-8h10v8M10 13v8M14 13v8"/>
  </svg>
)}
{name === "headset" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M4 14v-2a8 8 0 1 1 16 0v2"/>
    <path d="M4 14v3a2 2 0 0 0 2 2h1v-7H6a2 2 0 0 0-2 2zM20 14v3a2 2 0 0 1-2 2h-1v-7h1a2 2 0 0 1 2 2z"/>
  </svg>
)}
{name === "arrow-right" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M5 12h14M13 6l6 6-6 6"/>
  </svg>
)}
{name === "chevron-right" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M9 6l6 6-6 6"/>
  </svg>
)}
{name === "send" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M22 2L11 13"/>
    <path d="M22 2l-7 20-4-9-9-4z"/>
  </svg>
)}
{name === "mail" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <rect x="3" y="5" width="18" height="14" rx="2"/>
    <path d="M3 7l9 6 9-6"/>
  </svg>
)}
{name === "phone" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>
  </svg>
)}
{name === "clock-hours" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <circle cx="12" cy="12" r="9"/>
    <path d="M12 7v5l4 2"/>
  </svg>
)}
{name === "wave" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class={cls} aria-hidden="true">
    <path d="M2 12c2 0 2-4 4-4s2 8 4 8 2-8 4-8 2 4 4 4 2-2 4-2"/>
  </svg>
)}
{name === "logo" && (
  <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 40 40" fill="none" class={cls} aria-hidden="true">
    <defs>
      <linearGradient id="lg" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="var(--color-accent)"/>
        <stop offset="100%" stop-color="var(--color-accent-strong)"/>
      </linearGradient>
    </defs>
    <rect x="3" y="3" width="34" height="34" rx="8" fill="url(#lg)"/>
    <path d="M9 22h4l2.5-9 3 16 2.5-12 2 9h8" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" fill="none" opacity="0.95"/>
    <circle cx="32" cy="9" r="2" fill="var(--color-warm)"/>
  </svg>
)}
