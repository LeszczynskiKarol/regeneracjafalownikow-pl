---
import { siteConfig } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "./Icon.astro";

interface Props {
  current?: string;
}
const { current = "" } = Astro.props;

const navItems = [
  { href: "/#oferta", label: "Co naprawiamy", id: "oferta" },
  { href: "/#proces", label: "Proces", id: "proces" },
  { href: "/#przeglady", label: "Przeglądy", id: "przeglady" },
  { href: "/#faq", label: "FAQ", id: "faq" },
];
if (siteConfig.features.hasBlog) {
  navItems.push({ href: "/blog", label: "Blog", id: "blog" });
}
---

<header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-bg)]/75">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="group flex items-center gap-3 no-underline text-[var(--color-text)]" aria-label="Strona główna">
      <Icon name="logo" size={38} class="transition-transform group-hover:rotate-3" />
      <span class="flex flex-col leading-tight">
        <span class="font-serif text-[1.05rem] font-semibold tracking-tight">Regeneracja Falowników</span>
        <span class="text-[0.72rem] uppercase tracking-[0.16em] text-[var(--color-text-faint)]">Serwis · Diagnoza · Hamownia</span>
      </span>
    </a>

    <nav aria-label="Główne" class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={current === item.id ? "page" : undefined}
          class={`rounded-md px-3 py-1.5 text-[0.9375rem] no-underline transition-colors ${
            current === item.id
              ? "text-[var(--color-accent)] bg-[var(--color-accent-soft)]"
              : "text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-subtle)]"
          }`}
        >
          {item.label}
        </a>
      ))}
      <span class="mx-2 h-5 w-px bg-[var(--color-border)]" aria-hidden="true"></span>
      <a
        href="/#kontakt"
        class="btn-primary"
        style="padding: 0.5rem 1rem; font-size: 0.9rem;"
      >
        <Icon name="send" size={16} /> Wyceń naprawę
      </a>
      <ThemeToggle />
    </nav>

    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        type="button"
        id="nav-toggle"
        class="needs-js inline-flex h-10 w-10 items-center justify-center rounded-md border border-[var(--color-border)] text-[var(--color-text)] hover:bg-[var(--color-bg-subtle)]"
        aria-label="Otwórz menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-[var(--color-border)] md:hidden">
    <ul class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3 sm:px-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block rounded-md px-3 py-2 text-[var(--color-text-muted)] no-underline hover:bg-[var(--color-bg-subtle)] hover:text-[var(--color-text)]"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a href="/#kontakt" class="btn-primary w-full justify-center">
          <Icon name="send" size={16} /> Wyceń naprawę
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById("nav-toggle");
    var nav = document.getElementById("mobile-nav");
    if (!btn || !nav) return;
    btn.addEventListener("click", function () {
      var open = nav.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    });
    nav.querySelectorAll("a").forEach(function (a) {
      a.addEventListener("click", function () {
        nav.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>
