---
import { siteConfig } from "../config/site";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  current?: string;
}
const { current = "" } = Astro.props;

const navItems = [
  { href: "/#oferta", label: "Co naprawiamy", id: "oferta" },
  { href: "/#proces", label: "Proces", id: "proces" },
  { href: "/#przeglady", label: "Przeglądy", id: "przeglady" },
  { href: "/#faq", label: "FAQ", id: "faq" },
];
if (siteConfig.features.hasBlog) {
  navItems.push({ href: "/blog", label: "Blog", id: "blog" });
}
navItems.push({ href: "/#kontakt", label: "Kontakt", id: "kontakt" });
---

<header class="sticky top-0 z-40 border-b border-[var(--color-border)] bg-[var(--color-bg)]/85 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-bg)]/70">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2 font-serif text-lg font-semibold text-[var(--color-text)] no-underline">
      <svg width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect x="2" y="2" width="28" height="28" rx="4" stroke="currentColor" stroke-width="2" />
        <path d="M9 16h4l2-6 2 12 2-6h4" stroke="var(--color-accent)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none" />
      </svg>
      <span>Regeneracja Falowników</span>
    </a>

    <nav aria-label="Główne" class="hidden items-center gap-6 md:flex">
      {navItems.map((item) => (
        <a
          href={item.href}
          aria-current={current === item.id ? "page" : undefined}
          class="text-[0.9375rem] text-[var(--color-text-muted)] no-underline hover:text-[var(--color-text)]"
        >
          {item.label}
        </a>
      ))}
      <ThemeToggle />
    </nav>

    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        type="button"
        id="nav-toggle"
        class="needs-js inline-flex h-9 w-9 items-center justify-center rounded-md border border-[var(--color-border)] text-[var(--color-text)]"
        aria-label="Otwórz menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-[var(--color-border)] md:hidden">
    <ul class="mx-auto flex max-w-6xl flex-col gap-1 px-4 py-3 sm:px-6">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="block rounded-md px-3 py-2 text-[var(--color-text-muted)] no-underline hover:bg-[var(--color-bg-subtle)] hover:text-[var(--color-text)]"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById("nav-toggle");
    var nav = document.getElementById("mobile-nav");
    if (!btn || !nav) return;
    btn.addEventListener("click", function () {
      var open = nav.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", open ? "true" : "false");
    });
    nav.querySelectorAll("a").forEach(function (a) {
      a.addEventListener("click", function () {
        nav.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
      });
    });
  })();
</script>
